{
  "display_information": {
    "name": "Truedocs"
  },
  "features": {
    "slash_commands": [
      {
        "command": "/truedocs",
        "description": "Register and manage TrueDocs processes",
        "usage_hint": "register",
        "should_escape": false
      },
      {
        "command": "/truedocs-run",
        "description": "Scan this channel against Confluence and post a drift card",
        "usage_hint": "",
        "should_escape": false
      }
    ],
    "assistant_view": {
      "assistant_description": "I keep your runbooks honest — I watch Slack and tell you when your docs drift from reality.",
      "suggested_prompts": []
    },
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "Truedocs",
      "always_online": true
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "channels:history",
        "channels:join",
        "channels:read",
        "chat:write",
        "commands",
        "groups:history",
        "im:history",
        "im:read",
        "im:write",
        "reactions:write",
        "reactions:read",
        "users:read",
        "assistant:write"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_home_opened",
        "app_mention",
        "assistant_thread_started",
        "message.channels",
        "message.groups",
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
